# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
build/
dist/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Native runtime: an upstream clone built locally (see README). Not vendored.
/native/

# Compiled Cython extension (generated from _fastloop.pyx)
src/picopie/_fastloop.c
src/picopie/*.so

# Bundled native runtime (staged at build time by scripts/stage_runtime.py)
src/picopie/_lib/

# Example output
examples/_out/

# C# parity harness build artifacts (the .cs/.csproj are tracked)
parity/bin/
parity/obj/
parity-shapekernel/bin/
parity-shapekernel/obj/

# mkdocs build output
site/

# web viewer demo output (examples/web/demo.py)
web_demo.html

# Claude Code local settings
.claude/settings.local.json
